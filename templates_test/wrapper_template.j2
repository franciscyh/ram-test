//============================================================================
// Top Level Wrapper for {{ config_name }}
// Auto-generated by test_ram.py
//============================================================================

module top (
    // Clock - dedicated clock pin
    input  wire clk,
    
    // Control signals
    input  wire ena,
    input  wire wea,
{% if is_dual_port %}
    input  wire enb,
    input  wire web,
{% endif %}
    
    // Address inputs for Port A
    input  wire [{{ addr_a_width-1 }}:0] addr_a,
    
    // Data inputs for Port A  
    input  wire [{{ data_a_width-1 }}:0] data_in_a,
    
    // Data outputs for Port A
    output wire [{{ data_a_width-1 }}:0] data_out_a
{% if is_dual_port %}
    ,
    // Address inputs for Port B
    input  wire [{{ addr_b_width-1 }}:0] addr_b,
    
    // Data inputs for Port B
    input  wire [{{ data_b_width-1 }}:0] data_in_b,
    
    // Data outputs for Port B
    output wire [{{ data_b_width-1 }}:0] data_out_b
{% endif %}
);

{% if is_dual_port %}
    // Dummy DFF to hint Map tool that clk is a clock.
    // Map tool auto-recognizes CK of DFF as clock, but not CLKA/CLKB
    // of RAMB4_Sx_Sy. Without this hint, Map inserts IBUF instead of CLKBUF
    // for the clk port, causing Place to fail with "clk: illegal constraint".
    wire dummy_q;
    (* keep *)
    DFFHQ dummy_clk_dff (.D(1'b0), .CK(clk), .Q(dummy_q));
{% else %}
    // Internal clock - directly connect to clock input
    // (Clock buffer/BUFG is inserted automatically by the tool for single-port)
    wire clk_internal = clk;
{% endif %}

    // Instantiate the RAM IP (module name is "test" as generated by IP generator)
    test uut (
        .CLKA({% if is_dual_port %}clk{% else %}clk_internal{% endif %}),
        .ENA(ena),
        .WEA(wea),
        .ADDRA(addr_a),
        .DIA(data_in_a),
        .DOA(data_out_a)
{% if is_dual_port %}
        ,
        .CLKB(clk),
        .ENB(enb),
        .WEB(web),
        .ADDRB(addr_b),
        .DIB(data_in_b),
        .DOB(data_out_b)
{% endif %}
    );

endmodule
